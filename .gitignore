# ── Python ────────────────────────────────────────────────────────
venv/
venv*/
# Scoped to virtualenvs only: the previous '**/Lib/' pattern matched
# 'dashboard/src/lib/' on Windows (case-insensitive ignore matching),
# which silently excluded frontend source files from the repository.
venv*/Lib/
venv*/Lib64/
venv*/Scripts/
venv*/Include/
venv*/share/
*_env/
*_venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/
.ruff_cache/
.coverage_cache/
.pytest_tmp/
.pytest_cache/
.qwen_edit_cache/

