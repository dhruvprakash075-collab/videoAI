{
  "enabled": true,
  "name": "UIState Tests on Save",
  "description": "Run UIState unit tests automatically whenever test_uistate.py or conftest.py is saved, giving instant RED/GREEN feedback",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "tests/test_uistate.py",
      "tests/conftest.py"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "cd c:\\Video.AI && venv\\Scripts\\python.exe -m pytest tests/test_uistate.py -q --tb=short 2>&1",
    "timeout": 60
  }
}