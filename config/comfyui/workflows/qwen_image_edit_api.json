    "class_type": "QwenImageEdit2509Loader",
    "_meta": {
      "title": "Qwen-Image-Edit-2509 loader"
    }
  },
  "4": {
    "inputs": {
      "text": "__EDIT_PROMPT__",
      "model": ["3", 0]
    },
    "class_type": "QwenImageEditTextEncode",
    "_meta": {
      "title": "Edit prompt"
    }
  },
  "5": {
    "inputs": {
      "background_image": ["1", 0],
      "reference_image": ["2", 0],
