    "_meta": {
      "title": "Multi-image edit encode"
    }
  },
  "6": {
    "inputs": {
      "seed": "__SEED__",
      "steps": "__STEPS__",
      "cfg": "__CFG__",
      "denoise": "__DENOISE__",
