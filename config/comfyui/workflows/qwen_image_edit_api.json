      "model": ["3", 0]
    },
    "class_type": "QwenImageEditSampler",
    "_meta": {
      "title": "Qwen edit sampler"
    }
  },
  "7": {
    "inputs": {
      "samples": ["6", 0],
      "vae": ["3", 1]
