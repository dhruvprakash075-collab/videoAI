{
  "0": {
    "class_type": "VideoAI_FreeMemoryBarrier",
    "inputs": {
      "enabled": true,
      "unload_models": true,
      "free_cuda_cache": true,
      "label": "pre_load"
    }
  },
  "1": {
    "class_type": "VideoAI_ProjectConfigLoader",
    "inputs": {
      "config_path": "config/config.yaml",
      "repo_root": ""
    }
  },
  "2": {
    "class_type": "VideoAI_ConfigCheckpointLoader",
    "inputs": {
      "config_path": "config/config.yaml",
      "repo_root": "",
      "checkpoint_override": "",
      "barrier": ["0", 0]
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "cinematic portrait of the hero, dramatic lighting",
      "clip": ["2", 1]
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": ["1", 7],
      "clip": ["2", 1]
    }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": ["1", 0],
      "height": ["1", 1],
      "batch_size": 1
    }
  },
  "6": {
    "class_type": "VideoAI_ConfigKSampler",
    "inputs": {
      "model": ["2", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "latent": ["5", 0],
      "config_path": "config/config.yaml",
      "repo_root": "",
      "seed": 0,
      "seed_control": "fixed",
      "denoise": 1.0
    }
  },
  "7": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["6", 0],
      "vae": ["2", 2]
    }
  },
  "8": {
    "class_type": "VideoAI_VideoFrameSaver",
    "inputs": {
      "images": ["7", 0],
      "output_dir": "studio_outputs/frames",
      "scene_index": 1,
      "filename_prefix": "scene"
    }
  }
}
