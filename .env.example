# ── Video.AI Environment Variables ────────────────────────────────
# Copy this file to .env and fill in values as needed.
# None of these are required for basic operation — the pipeline works
# fully offline with Ollama + local models. These are for optional features.

# ── Ollama (usually auto-detected, no change needed) ──────────────
# OLLAMA_MODELS=C:\models          # Where Ollama stores model files

# ── Director consultation timeout ─────────────────────────────────
# DIRECTOR_TIMEOUT=300             # Seconds to wait for user reply (0 = no timeout)

# ── Optional: Pexels stock images (fallback when SD fails) ────────
# PEXELS_API_KEY=your_pexels_api_key_here

# ── Optional: Notion API integration ──────────────────────────────
# NOTION_TOKEN=secret_your_notion_integration_token_here
# NOTION_DEFAULT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_DEFAULT_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional: Sentry error tracking ───────────────────────────────
# SENTRY_DSN=https://public@example.ingest.sentry.io/123456
# SENTRY_ENVIRONMENT=local
# SENTRY_RELEASE=video-ai@0.0.0

# ── Performance tuning ────────────────────────────────────────────
# TORCHDYNAMO_SUPPRESS_ERRORS=1    # Already set by bootstrap (suppress torch.compile warnings)
# PYTHONIOENCODING=utf-8           # Already set by bootstrap (Windows console fix)
# OPENAI_MAX_RETRIES=0             # Already set by core/main.py (prevent CrewAI silent retries)
